{
  "name": "coachhive",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run clean:next && WATCHPACK_POLLING=true next dev -H 127.0.0.1 -p 3000",
    "build": "next build --webpack",
    "clean:next": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "dev:clean": "npm run dev",
    "build:clean": "npm run clean:next && npm run build",
    "start": "next start",
    "lint": "next lint",
    "test:ui": "playwright test",
    "audit:api": "node scripts/audit-api-security.mjs",
    "email:templates:sync": "node scripts/postmark-sync-templates.mjs",
    "email:templates:dry-run": "node scripts/postmark-sync-templates.mjs --dry-run"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.38.0",
    "@stripe/react-stripe-js": "^5.4.1",
    "@stripe/stripe-js": "^8.6.0",
    "@supabase/auth-helpers-nextjs": "0.8.7",
    "@supabase/supabase-js": "^2.102.1",
    "mixpanel-browser": "^2.77.0",
    "next": "^16.2.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "stripe": "^20.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "18.17.17",
    "@types/react": "18.2.21",
    "@types/react-dom": "18.2.7",
    "autoprefixer": "10.4.15",
    "eslint": "8.57.0",
    "eslint-config-next": "^16.2.2",
    "postcss": "^8.5.9",
    "tailwindcss": "3.3.3",
    "typescript": "5.2.2"
  }
}
