# Copy this file to `.env.local` for local development.
# `.env.local` is intentionally ignored by Git and should never be committed.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_MIXPANEL_TOKEN=
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
PAYOUT_CRON_SECRET=
REMINDER_CRON_SECRET=
INTEGRATIONS_STATE_SECRET=
SUPABASE_SEND_EMAIL_HOOK_SECRET=

# Google OAuth (Calendar + Meet)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Zoom OAuth
ZOOM_OAUTH_CLIENT_ID=
ZOOM_OAUTH_CLIENT_SECRET=

# Marketplace preview
MARKETPLACE_PREVIEW=false
NEXT_PUBLIC_MARKETPLACE_PREVIEW=false

# Support + Gmail ingest
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SUPPORT_EMAIL=
SUPPORT_WEBHOOK_SECRET=
GMAIL_PUBSUB_TOPIC=
SUPPORT_GMAIL_LABEL=

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_ENVIRONMENT=
SENTRY_ENABLED=true
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Postmark
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=
POSTMARK_MESSAGE_STREAM=outbound
POSTMARK_WEBHOOK_SECRET=

# E2E Test Credentials (Playwright)
# Create one Supabase test account per role and fill in below
E2E_COACH_EMAIL=
E2E_COACH_PASSWORD=
E2E_ATHLETE_EMAIL=
E2E_ATHLETE_PASSWORD=
E2E_ADMIN_EMAIL=
E2E_ADMIN_PASSWORD=
E2E_ORG_EMAIL=
E2E_ORG_PASSWORD=
